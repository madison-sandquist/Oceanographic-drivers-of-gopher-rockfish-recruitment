# DO
anova_do <- aov(Value ~ Period * ESM,
data = dplyr::filter(future_long, Variable == "DO"))
summary(anova_do)
# pH
anova_ph <- aov(Value ~ Period * ESM,
data = dplyr::filter(future_long, Variable == "pH"))
summary(anova_ph)
# Temperature
anova_temp <- aov(Value ~ Period * ESM,
data = dplyr::filter(future_long, Variable == "Temperature"))
summary(anova_temp)
# DO
anova_do <- aov(Value ~ Period + ESM,
data = dplyr::filter(future_long, Variable == "DO"))
summary(anova_do)
# pH
anova_ph <- aov(Value ~ Period + ESM,
data = dplyr::filter(future_long, Variable == "pH"))
summary(anova_ph)
# Temperature
anova_temp <- aov(Value ~ Period + ESM,
data = dplyr::filter(future_long, Variable == "Temperature"))
summary(anova_temp)
