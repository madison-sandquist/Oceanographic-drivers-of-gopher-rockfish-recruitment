plot_2050_2070
plot_2050_2070 <- plot_2050_2070 +
scale_y_continuous(limits = c(60e6, 120e6),
labels = scales::label_number(scale = 1e-6, accuracy = 1))
plot_2070_2100 <- plot_2070_2100 +
scale_y_continuous(limits = c(60e6, 120e6),
labels = scales::label_number(scale = 1e-6, accuracy = 1))
plot_2020_2050 + plot_2050_2070  +  plot_2070_2100
ggsave("box_plot_comparison.png",  width = 15, height = 5)
ggsave("box_plot_comparison.png",  width = 17, height = 5)
plot_2020_2050 <- plot_2020_2050 +
scale_y_continuous(limits = c(60e6, 120e6),
labels = scales::label_number(scale = 1e-6, accuracy = 1))+ +
scale_x_discrete(labels = c("Combined Stressor (PC1)" = "Combined Stressor",
"Dissolved Oxygen" = "DO",
"pH" = "pH"))
