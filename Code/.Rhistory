future_ocean2 <- future_ocean %>%
filter(Month %in% c("Jan", 'Feb', 'Mar', 'Apr', 'May', 'Jun', 'Jul', 'Aug'))
# annual means by ESM
future_annual <- future_ocean2 %>%
group_by(ESM, Year) %>%
summarize(
DO = mean(DO_avg, na.rm = TRUE),
pH = mean(pH_avg, na.rm = TRUE),
Temperature = mean(Temperature_avg, na.rm = TRUE),
.groups = "drop"
)
# long format
future_long <- future_annual %>%
pivot_longer(
cols = c(DO, pH, Temperature),
names_to = "Variable",
values_to = "Value"
)
library(dplyr)
library(tidyr)
library(ggplot2)
library(patchwork)
# 1. Annual means by ESM
future_annual <- future_ocean %>%
group_by(ESM, Year) %>%
summarize(
DO = mean(DO_avg, na.rm = TRUE),
pH = mean(pH_avg, na.rm = TRUE),
Temperature = mean(Temperature_avg, na.rm = TRUE),
.groups = "drop"
)
# 2. Common theme
fig_theme <- theme_classic(base_size = 14) +
theme(
legend.position = "bottom"
)
# 3. DO plot
p_do <- ggplot(future_annual, aes(x = Year, y = DO, color = ESM)) +
geom_line(linewidth = 1, alpha = .5) +
geom_smooth(method = "lm", se = FALSE, linetype = "dashed", linewidth = 0.8) +
labs(
title = "",
x = NULL,
y = "DO (mg/L)"
) +
scale_color_manual(values = ESM_colors, name = "Model") +
fig_theme
# 4. pH plot
p_ph <- ggplot(future_annual, aes(x = Year, y = pH, color = ESM)) +
geom_line(linewidth = 1, alpha = .5) +
geom_smooth(method = "lm", se = FALSE, linetype = "dashed", linewidth = 0.8) +
labs(
title = "",
x = NULL,
y = "pH"
) +
scale_color_manual(values = ESM_colors, name = "Model") +
fig_theme
# 5. Temperature plot
p_temp <- ggplot(future_annual, aes(x = Year, y = Temperature, color = ESM)) +
geom_line(linewidth = 1, alpha = .5) +
geom_smooth(method = "lm", se = FALSE, linetype = "dashed", linewidth = 0.8) +
labs(
title = "",
x = "Year",
y = expression(Temperature~(degree*C))
) +
scale_color_manual(values = ESM_colors, name = "Model") +
fig_theme
# 6. Combine
final_plot <- p_do / p_ph / p_temp +
plot_layout(guides = "collect") &
theme(legend.position = "bottom")
final_plot
final_boxplot <- (p_do | p_do_box /
p_ph| p_ph_box/
p_temp | p_temp_box) +
plot_layout(guides = "collect") &
theme(legend.position = "right")
final_plt_2 <- (p_do | p_do_box /
p_ph| p_ph_box/
p_temp | p_temp_box) +
plot_layout(guides = "collect") &
theme(legend.position = "right")
final_plt_2
final_plt_2 <- (
(p_do   | p_do_box)   /
(p_ph   | p_ph_box)   /
(p_temp | p_temp_box)
) +
plot_layout(guides = "collect") &
theme(legend.position = "right")
final_plt_2
ggsave('Figures/fig8.png', width = 8, height = 11, dpi = 300)
plots <- list(
p_do = p_do,
p_do_box = p_do_box,
p_ph = p_ph,
p_ph_box = p_ph_box,
p_temp = p_temp,
p_temp_box = p_temp_box
)
for (name in names(plots)) {
ggsave(
filename = file.path("figures", paste0(name, ".png")),
plot = plots[[name]],
width = 6,
height = 4,
dpi = 300
)
}
