set.seed(123)
n_sims <- 1000
# Pre-compute SPR 35% baseline - doesn't change
spr35_base_mean <- df_all %>%
filter(model == "SPR 35%") %>%
filter(between(Year, 2050, 2070)) %>%
group_by(Year) %>%
summarise(annual_total = sum(Larvae_base, na.rm = TRUE), .groups = "drop") %>%
summarise(mean_annual_total = mean(annual_total, na.rm = TRUE)) %>%
pull(mean_annual_total)
run_bootstrap <- function(model_obj, stressor_var) {
coefs <- coef(model_obj)
vcov_mat <- vcov(model_obj)
formula_str <- as.formula(paste("~ log_Length +", stressor_var))
base_data <- df_all %>%
filter(model == "SPR 45%") %>%
filter(between(Year, 2050, 2070)) %>%
filter(!is.na(log_Length), !is.na(.data[[stressor_var]]))
X_mat <- model.matrix(formula_str, data = base_data)
fish_vec <- base_data$fish
year_vec <- base_data$Year   # <-- needed to sum within year
stopifnot(all(names(coefs) == colnames(X_mat)))
stopifnot(length(fish_vec) == nrow(X_mat))
stopifnot(length(year_vec) == nrow(X_mat))
sim_means <- replicate(n_sims, {
new_coefs <- mvrnorm(1, mu = coefs, Sigma = vcov_mat)
F_sim <- exp(X_mat %*% new_coefs)
Larvae_sim <- as.numeric(fish_vec * F_sim)
# sum across the 18 length bins WITHIN each year, then average those
# annual totals across projection years
tibble(Year = year_vec, Larvae_sim = Larvae_sim) %>%
group_by(Year) %>%
summarise(annual_total = sum(Larvae_sim, na.rm = TRUE), .groups = "drop") %>%
summarise(mean_annual_total = mean(annual_total, na.rm = TRUE)) %>%
pull(mean_annual_total)
})
crossover_rate <- mean(sim_means < spr35_base_mean)
list(stressor = stressor_var, crossover_rate = crossover_rate, sim_means = sim_means)
}
results_PC1 <- run_bootstrap(model_pc, "PC1")
results_DO  <- run_bootstrap(model_DO,  "DO")
results_pH  <- run_bootstrap(model_pH,  "pH")
cat("PC1 crossover:", round(results_PC1$crossover_rate * 100, 1), "%\n")
cat("DO  crossover:", round(results_DO$crossover_rate  * 100, 1), "%\n")
cat("pH  crossover:", round(results_pH$crossover_rate  * 100, 1), "%\n")
# Combined visualisation
bind_rows(
tibble(sim_mean = results_PC1$sim_means, stressor = "Combined Stressor (PC1)"),
tibble(sim_mean = results_DO$sim_means,  stressor = "Dissolved Oxygen"),
tibble(sim_mean = results_pH$sim_means,  stressor = "pH")
) %>%
mutate(stressor = factor(stressor,
levels = c("Combined Stressor (PC1)",
"Dissolved Oxygen", "pH"))) %>%
ggplot(aes(x = sim_mean)) +
geom_histogram(bins = 50, fill = "#F18932", color = "white") +
geom_vline(xintercept = spr35_base_mean,
color = "#9E3D22", linewidth = 1.2, linetype = "dashed") +
facet_wrap(~stressor, nrow = 3) +
scale_x_continuous(labels = scales::comma) +
labs(
x = "Mean annual larval output (SPR 45% with environment)",
y = "Count"
#  title = "Sensitivity analysis: coefficient uncertainty across OAH models",
#  subtitle = paste0("Dashed line = SPR 35% length-only benchmark (n = ",
#                   n_sims, " simulations)")
) +
theme_bw() +
theme(
legend.position = "none",
panel.grid.minor = element_blank(),
axis.text.x = element_text(size = 13)
) +
larger_axis_theme +
theme(strip.text = element_text(size = 13))
ggsave('fishing_climate_projections_boxplots_sensativity_analysis.png', width = 8, height = 6)
crossover_summary <- bind_rows(
tibble(Driver = "Combined Stressor (PC1)",
sim_mean = results_PC1$sim_means,
crossover_rate = results_PC1$crossover_rate),
tibble(Driver = "Dissolved Oxygen",
sim_mean = results_DO$sim_means,
crossover_rate = results_DO$crossover_rate),
tibble(Driver = "pH",
sim_mean = results_pH$sim_means,
crossover_rate = results_pH$crossover_rate)
) %>%
mutate(Driver = factor(Driver, levels = c("Combined Stressor (PC1)",
"Dissolved Oxygen", "pH")))
crossover_table <- crossover_summary %>%
group_by(Driver) %>%
summarise(
n_sims = n(),
pct_below_benchmark = round(100 * mean(crossover_rate), 1),
median_sim_mean = median(sim_mean),
.groups = "drop"
)
crossover_table
plot_2050_2070 <- ggplot(crossover_summary, aes(x = Driver, y = sim_mean)) +
geom_boxplot(alpha = 0.85, width = 0.5, show.legend = FALSE) +
# annotate("text", x = Inf, y = spr35_base_mean,
#       label = "SPR 35% length-only benchmark",
#      hjust = 1.05, vjust = -0.6, size = 3.8, fontface = "italic", color = "#9E3D22") +
geom_hline(yintercept = spr35_base_mean, linetype = "dashed",
color = "#9E3D22", linewidth = 1) +
labs(x = NULL,
y = "Annual larval output (millions) for \n environmentally informed SPR 45% model ") +
theme_bw() +
scale_y_continuous(labels = scales::label_number(scale = 1e-6, accuracy = 0.1)) +
theme(panel.grid.minor = element_blank()) +
larger_axis_theme
plot_2050_2070
plot_2050_2070 <- plot_2050_2070 +
scale_y_continuous(limits = c(60e6, 120e6),
labels = scales::label_number(scale = 1e-6, accuracy = 1))
plot_2070_2100 <- plot_2070_2100 +
scale_y_continuous(limits = c(60e6, 120e6),
labels = scales::label_number(scale = 1e-6, accuracy = 1))
plot_2050_2070  +  plot_2070_2100
ggsave("box_plot_comparison",  width = 10, height = 5)
plot <- plot_2050_2070  +  plot_2070_2100
ggsave("box_plot_comparison",  width = 10, height = 5)
ggsave("box_plot_comparison.png",  width = 10, height = 5)
